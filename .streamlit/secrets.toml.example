# Streamlit Cloud secrets — copy to secrets.toml and fill in values.
# On Streamlit Community Cloud, paste these under Settings → Secrets.

DATABASE_URL = "postgresql+asyncpg://user:password@host:5432/el_ops"
REDIS_URL = "redis://localhost:6379/0"

SLACK_CLIENT_ID = ""
SLACK_CLIENT_SECRET = ""

GITHUB_CLIENT_ID = ""
GITHUB_CLIENT_SECRET = ""

ANTHROPIC_API_KEY = ""
ANTHROPIC_MODEL = "claude-sonnet-4-6"

APP_BASE_URL = "https://yourapp.streamlit.app"
# Required for signed session cookies — use a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY = ""

ENABLE_AI_EXTRACTION = true

# ─── Google Sheets (Developer Track) ──────────────────────────────────────────
# Paste the full service-account JSON as a single-line string (escape inner
# quotes or use TOML's triple-single-quote literal string form). Share the
# sheet with the service account's `client_email` (Viewer is enough).
# See README → "Developer Track (Google Sheets)" for step-by-step setup.
GOOGLE_SHEETS_CREDENTIALS_JSON = ""
DEV_TRACK_SHEET_ID = ""
