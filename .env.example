# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
# Set to your Streamlit Cloud URL for production (e.g. https://yourapp.streamlit.app)
APP_BASE_URL=https://localhost:8501

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/el_ops
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Slack OAuth app (Sign in with Slack — no bot, no event subscriptions)
# Create at api.slack.com/apps → OAuth & Permissions → User Token Scopes
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret

# GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Developer Track (Google Sheets)
# Paste the full service-account JSON as a single-line string. Share the
# sheet with the service account's client_email as Editor (required for the
# Notion Dev Track Sync writes below).
# See README → "Developer Track (Google Sheets)" for setup.
GOOGLE_SHEETS_CREDENTIALS_JSON=
DEV_TRACK_SHEET_ID=

# Notion Dev Track Sync
# NOTION_API_KEY: Internal Integration Secret (Notion → Settings →
#   Connections → Develop or manage integrations → New integration).
#   Remember to share the target database with the integration.
# NOTION_DEV_TRACK_DATABASE_ID: ID of the database whose entries are one
#   per developer (page title format: "{dev name} <> {manager name}").
#   Copy from the database URL: notion.so/.../{DATABASE_ID}?v=...
# See README → "Notion Dev Track Sync" for setup.
NOTION_API_KEY=
NOTION_DEV_TRACK_DATABASE_ID=

# Feature flags (MVP)
ENABLE_AI_EXTRACTION=true
ENABLE_BURNOUT_DETECTION=false
ENABLE_ORG_ANALYTICS=false

# Rate limiting
GITHUB_API_REQUESTS_PER_HOUR=5000
SLACK_API_REQUESTS_PER_MINUTE=50
AI_REQUESTS_PER_MINUTE=20
